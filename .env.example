# ─── Trakt API ────────────────────────────────────────────────────────────────
# Create an application at https://trakt.tv/oauth/applications to get these.
TRAKT_CLIENT_ID=your_client_id_here
TRAKT_CLIENT_SECRET=your_client_secret_here

# OAuth tokens — see README.md for instructions on obtaining these.
TRAKT_ACCESS_TOKEN=your_access_token_here
TRAKT_REFRESH_TOKEN=your_refresh_token_here

# Your Trakt username (shown in your profile URL: trakt.tv/users/<username>)
TRAKT_USERNAME=your_trakt_username

# ─── SMTP (Email Notifications) ───────────────────────────────────────────────
# Gmail users: generate an App Password at
#   https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
SMTP_TO=recipient@example.com

# ─── Optional Tuning ──────────────────────────────────────────────────────────
# Minimum price drop percentage required to send a notification (default: 20.0)
# DISCOUNT_THRESHOLD_PERCENT=20.0

# How often to check prices, in hours (default: 24.0)
# CHECK_INTERVAL_HOURS=24.0

# Minimum delay between external API requests, in seconds (default: 1.5)
# API_REQUEST_INTERVAL_SECONDS=1.5

# SQLite database path inside the container (default: /data/prices.db)
# DB_PATH=/data/prices.db

# Logging verbosity: CRITICAL, ERROR, WARNING, INFO, DEBUG, or NOTSET (default: INFO)
# LOG_LEVEL=INFO

# Email theme: "dark" or "light" (default: dark)
# EMAIL_THEME=dark

# App version shown in email footer (optional)
# APP_VERSION=1.0.0
